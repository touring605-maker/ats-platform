# =============================================================================
# ATS Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env files with real secrets.
# =============================================================================

# --- Application ---
NODE_ENV=development                                # development | staging | production
PORT=3000                                           # Server port

# --- Database ---
DATABASE_URL=postgres://user:password@localhost:5432/ats_dev   # PostgreSQL connection string
DB_POOL_MIN=2                                       # Minimum connection pool size
DB_POOL_MAX=10                                      # Maximum connection pool size
DB_SSL=true                                         # Enable SSL for DB connections

# --- Authentication (OIDC) ---
AUTH_ISSUER=https://login.microsoftonline.com/{tenant-id}/v2.0  # Identity provider issuer URL
AUTH_AUDIENCE=api://ats-platform                    # Expected audience claim in JWT

# --- Cloud Provider ---
CLOUD_PROVIDER=azure                                # azure | aws | gcp
STORAGE_PROVIDER=azure-blob                         # azure-blob | s3 | gcs
MESSAGING_PROVIDER=servicebus                       # servicebus | sqs | pubsub

# --- AI Service ---
AI_SERVICE_API_KEY=your-api-key-here                # AI provider API key

# --- Email ---
EMAIL_FROM=noreply@example.com                      # Default sender address
EMAIL_PROVIDER=sendgrid                             # sendgrid | ses | mailgun

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000           # Comma-separated allowed origins

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000                          # Rate limit window in milliseconds
RATE_LIMIT_MAX_REQUESTS=100                         # Max requests per window

# --- Feature Flags ---
FEATURE_AI_SCREENING=false                          # Enable AI-assisted screening
FEATURE_MARKETPLACE=false                           # Enable marketplace integrations
FEATURE_ADVANCED_ANALYTICS=false                    # Enable advanced analytics
FEATURE_BULK_IMPORT=false                           # Enable bulk data import
FEATURE_ESIGNATURE=false                            # Enable e-signature integration
